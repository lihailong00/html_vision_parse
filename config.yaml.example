# HTML Vision Parse Configuration
# Copy to config.yaml and modify as needed

browser:
  # Browser type: "chromium", "firefox", or "webkit"
  type: "chromium"
  # Run browser in headless mode
  headless: true
  # Viewport dimensions
  viewport_width: 1920
  viewport_height: 1080
  # Capture full page vs just visible area
  full_page: true
  # Wait condition: "load", "domcontentloaded", "networkidle"
  wait_until: "networkidle"
  # Page load timeout in ms
  wait_timeout: 30000
  # User agent string
  user_agent: "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

api:
  # API server host
  host: "0.0.0.0"
  # API server port
  port: 18765
  # LLM provider: "claude", "gpt", "gemini"
  provider: "claude"
  # API key (leave empty to use environment variable)
  api_key: ""
  # Model name (leave empty to use provider default)
  model: ""
